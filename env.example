# ─── Copy this file to .env.local for local dev, and add the same keys
#     in the Vercel dashboard (Project > Settings > Environment Variables). ───

# Auth (make this a long random string — used to sign login tokens)
JWT_SECRET=change-me-to-a-long-random-string

# Airtable
AIRTABLE_TOKEN=pat_xxxxxxxxxxxxxxxx        # Personal Access Token (scopes: data read/write)
AIRTABLE_BASE_ID=appxxxxxxxxxxxxxx          # the base ID for "YGTAR 2026"

# Cloudinary (cloud name + key are public; SECRET must stay server-side)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=xxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxx

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxxx          # use sk_test_ while testing
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx        # from the webhook you create in Stripe

# Resend (transactional email + campaigns)
RESEND_API_KEY=re_xxxxxxxx
FROM_EMAIL=info@naturalselectionar.com

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_FROM_NUMBER=+15065551234             # your Twilio number

# Registration: $20.00 base per racer, plus $5.00 per city per racer (below)
REGISTRATION_PRICE_CENTS=2000
CITY_PRICE_CENTS=500             # $5.00 per city, per racer
